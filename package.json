{
  "name": "dino-os",
  "version": "1.0.0",
  "description": "Futuristic AI Desktop Assistant - DINO OS with holographic cyberpunk interface",
  "main": "frontend/src/electron/main.js",
  "homepage": "./",
  "author": "Vedant",
  "license": "MIT",
  "scripts": {
    "start": "set PORT=3001&& set BROWSER=none&& npm --prefix frontend start",
    "build": "npm --prefix frontend run build",
    "react-start": "set PORT=3001&& set BROWSER=none&& npm --prefix frontend start",
    "react-build": "npm --prefix frontend run build",
    "electron-start": "wait-on http://localhost:3001 && set ELECTRON_RUN_AS_NODE=&& electron .",
    "electron-dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3001 && set ELECTRON_RUN_AS_NODE=&& electron .\"",
    "electron-build": "npm run react-build && electron-builder",
    "dev": "npm run electron-dev",
    "build-app": "npm run electron-build",
    "backend": "cd backend && venv\\Scripts\\python.exe -m uvicorn main:app --reload --port 8000",
    "voice": "cd backend && venv\\Scripts\\python.exe -u voice_listener.py",
    "start-all": "concurrently \"npm run backend\" \"npm run electron-dev\" \"npm run voice\""
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "framer-motion": "^10.16.0",
    "three": "^0.156.0",
    "tailwindcss": "^3.3.0",
    "axios": "^1.6.0",
    "lucide-react": "^0.263.1",
    "classnames": "^2.3.2",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "concurrently": "^8.2.0",
    "wait-on": "^7.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "postcss": "^8.4.31",
    "autoprefixer": "^10.4.16"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.dino.os",
    "files": [
      "build/**/*",
      "frontend/src/electron/main.js",
      "frontend/src/electron/preload.js",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    }
  }
}
