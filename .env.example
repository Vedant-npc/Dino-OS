# DINO OS Environment Variables

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Configuration (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Server Configuration
DEBUG=False
HOST=0.0.0.0
PORT=8000

# Voice Configuration
VOICE_ENABLED=True
TTS_ENABLED=True

# AI Configuration
AI_MODEL=gemini-pro
TEMPERATURE=0.7
MAX_COMMAND_TIMEOUT=30

# Database (optional)
DATABASE_URL=sqlite:///./dino.db

# System
ALLOWED_COMMANDS=open,close,search,screenshot,create-folder,read-text,lock,shutdown,restart,coding-mode,open-project
